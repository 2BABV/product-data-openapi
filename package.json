{
  "scripts": {
    "lint": "redocly lint --config openapi/redocly.yaml product@v1 tradeitem@v1",
    "lint:all": "redocly lint --config openapi/redocly.yaml product@v1 tradeitem@v1 tradeitem-domain@v1 netprice@v1 stock@v1",
    "bundle:product": "redocly bundle --config openapi/redocly.yaml product@v1 -o openapi/apis/product/generated/product-api.yaml",
    "bundle:tradeitem": "redocly bundle --config openapi/redocly.yaml tradeitem@v1 -o openapi/apis/tradeitem/generated/tradeitem-api.yaml",
    "bundle": "npm run bundle:product && npm run bundle:tradeitem",
    "build:product": "redocly build-docs --config openapi/redocly.yaml product@v1 -o openapi/apis/product/generated/product.html",
    "build:tradeitem": "redocly build-docs --config openapi/redocly.yaml tradeitem@v1 -o openapi/apis/tradeitem/generated/tradeitem.html",
    "build:docs": "npm run build:product && npm run build:tradeitem",
    "build:models": "node scripts/generate-model-docs.mjs"
  },
  "devDependencies": {
    "@redocly/cli": "^2.15.1"
  }
}
